# ---------------------------------------------------------------------------
# TrojanSpec-Bench environment template
# Copy to `.env` and fill in the backends you have. You need AT LEAST ONE
# LLM backend. Nothing here requires any single proprietary provider.
# ---------------------------------------------------------------------------

# --- OpenRouter (recommended: one key, many model families) ----------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Anthropic (Claude as elicitor / monitor) ------------------------------
ANTHROPIC_API_KEY=

# --- OpenAI (GPT-4o as elicitor / monitor) ---------------------------------
OPENAI_API_KEY=

# --- Ollama (local, free; runs on your own GPU) ----------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# --- HuggingFace (only for Phase 13 dataset release) -----------------------
HF_TOKEN=
