# ---------------------------------------------------------------------------
# TrojanSpec-Bench environment template
# Copy to `.env` and fill in the backends you have. You need AT LEAST ONE
# LLM backend. Nothing here requires any single proprietary provider.
# ---------------------------------------------------------------------------

# --- Fireworks AI (PRIMARY backend: one key, four model families) ----------
# https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# --- OpenRouter (optional fallback) ----------------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Anthropic (Claude as elicitor / monitor) ------------------------------
ANTHROPIC_API_KEY=

# --- OpenAI (GPT-4o as elicitor / monitor) ---------------------------------
OPENAI_API_KEY=

# --- Ollama (local, free; runs on your own GPU) ----------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# --- HuggingFace (only for Phase 13 dataset release) -----------------------
HF_TOKEN=

# AWS Bedrock (required for all Phase 5/9/10/11 generation and judging)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
